@model DZ3_ASOIU.Models.City

@{
    ViewData["Title"] = "Добавление города";
}

<div class="animate-fade-in" style="max-width: 600px; margin: 0 auto;">
    <div class="mb-4">
        <h1 class="card-title-gradient m-0">Добавить город</h1>
        <p class="text-secondary m-0">Ввод нового города и привязка к стране</p>
    </div>

    <div class="custom-card">
        <form asp-action="Create">
            <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

            <div class="form-group mb-3">
                <label asp-for="CountryId" class="control-label">Страна</label>
                <select asp-for="CountryId" class="form-select custom-input" asp-items="ViewBag.Countries">
                    <option value="">-- Выберите страну --</option>
                </select>
                <span asp-validation-for="CountryId" class="text-danger mt-1 d-block small"></span>
            </div>

            <div class="form-group mb-3">
                <label asp-for="Name" class="control-label">Название города</label>
                <input asp-for="Name" class="form-control custom-input" placeholder="Введите название города..." autocomplete="off" />
                <span asp-validation-for="Name" class="text-danger mt-1 d-block small"></span>
            </div>

            <div class="form-group mb-4">
                <label asp-for="PopulationK" class="control-label">Население (тыс. чел.)</label>
                <input asp-for="PopulationK" type="number" min="0" class="form-control custom-input" placeholder="Введите численность населения..." />
                <span asp-validation-for="PopulationK" class="text-danger mt-1 d-block small"></span>
            </div>

            <div class="d-flex gap-3 justify-content-end">
                <a asp-action="Index" class="btn btn-outline-custom">
                    Отмена
                </a>
                <button type="submit" class="btn btn-primary-gradient">
                    💾 Сохранить
                </button>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
