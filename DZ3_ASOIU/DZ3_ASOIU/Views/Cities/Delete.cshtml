@model DZ3_ASOIU.Models.City

@{
    ViewData["Title"] = "Удаление города";
}

<div class="animate-fade-in" style="max-width: 600px; margin: 0 auto;">
    <div class="mb-4 text-center">
        <h1 class="card-title-gradient m-0">Удаление города</h1>
        <p class="text-secondary m-0">Подтвердите ваше действие</p>
    </div>

    <div class="custom-card border-danger">
        <h3 class="h4 fw-bold text-center mb-4">Вы уверены, что хотите удалить этот город?</h3>

        <div class="mb-4 p-3 rounded bg-dark border-1" style="border: 1px solid var(--border-color);">
            <div class="row">
                <div class="col-sm-4 text-secondary fw-semibold">ID Города:</div>
                <div class="col-sm-8 text-light fw-bold">@Model.Id</div>
            </div>
            <div class="row mt-2">
                <div class="col-sm-4 text-secondary fw-semibold">Название:</div>
                <div class="col-sm-8 text-light fw-bold">@Model.Name</div>
            </div>
            <div class="row mt-2">
                <div class="col-sm-4 text-secondary fw-semibold">Страна:</div>
                <div class="col-sm-8 text-light fw-bold">@(Model.Country != null ? Model.Country.Name : "Не указана")</div>
            </div>
            <div class="row mt-2">
                <div class="col-sm-4 text-secondary fw-semibold">Население:</div>
                <div class="col-sm-8 text-light fw-bold">@Model.PopulationK тыс. чел.</div>
            </div>
        </div>

        <form asp-action="Delete" class="text-center">
            <input type="hidden" asp-for="Id" />
            <div class="d-flex gap-3 justify-content-center">
                <a asp-action="Index" class="btn btn-outline-custom">
                    Отмена
                </a>
                <button type="submit" class="btn btn-danger-custom px-4">
                    🗑️ Да, удалить город
                </button>
            </div>
        </form>
    </div>
</div>
