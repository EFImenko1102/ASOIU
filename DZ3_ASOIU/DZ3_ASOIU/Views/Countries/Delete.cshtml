@model DZ3_ASOIU.Models.Country

@{
    ViewData["Title"] = "Удаление страны";
}

<div class="animate-fade-in" style="max-width: 600px; margin: 0 auto;">
    <div class="mb-4 text-center">
        <h1 class="card-title-gradient m-0">Удаление страны</h1>
        <p class="text-secondary m-0">Подтвердите ваше действие</p>
    </div>

    <div class="custom-card border-danger">
        <h3 class="h4 fw-bold text-center mb-4">Вы уверены, что хотите удалить эту страну?</h3>
        
        <div class="mb-4 p-3 rounded bg-dark border-1" style="border: 1px solid var(--border-color);">
            <div class="row">
                <div class="col-sm-4 text-secondary fw-semibold">ID Страны:</div>
                <div class="col-sm-8 text-light fw-bold">@Model.Id</div>
            </div>
            <div class="row mt-2">
                <div class="col-sm-4 text-secondary fw-semibold">Название:</div>
                <div class="col-sm-8 text-light fw-bold">@Model.Name</div>
            </div>
        </div>

        @if (ViewBag.HasCities == true)
        {
            <div class="alert alert-danger d-flex align-items-center mb-4" role="alert">
                <span class="fs-4 me-3">⚠️</span>
                <div>
                    <strong>Внимание!</strong> Невозможно удалить эту страну, так как с ней связаны города в базе данных. Сначала удалите города этой страны.
                </div>
            </div>

            <div class="text-center">
                <a asp-action="Index" class="btn btn-primary-gradient w-100">
                    Вернуться к списку стран
                </a>
            </div>
        }
        else
        {
            <form asp-action="Delete" class="text-center">
                <input type="hidden" asp-for="Id" />
                <div class="d-flex gap-3 justify-content-center">
                    <a asp-action="Index" class="btn btn-outline-custom">
                        Отмена
                    </a>
                    <button type="submit" class="btn btn-danger-custom px-4">
                        🗑️ Да, удалить страну
                    </button>
                </div>
            </form>
        }
    </div>
</div>
