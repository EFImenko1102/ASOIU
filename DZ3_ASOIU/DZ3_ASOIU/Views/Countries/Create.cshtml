@model DZ3_ASOIU.Models.Country

@{
    ViewData["Title"] = "Добавление страны";
}

<div class="animate-fade-in" style="max-width: 600px; margin: 0 auto;">
    <div class="mb-4">
        <h1 class="card-title-gradient m-0">Добавить страну</h1>
        <p class="text-secondary m-0">Создание нового элемента в справочнике стран</p>
    </div>

    <div class="custom-card">
        <form asp-action="Create">
            <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

            <div class="form-group mb-4">
                <label asp-for="Name" class="control-label">Название страны</label>
                <input asp-for="Name" class="form-control custom-input" placeholder="Введите название страны..." autocomplete="off" />
                <span asp-validation-for="Name" class="text-danger mt-1 d-block small"></span>
            </div>

            <div class="d-flex gap-3 justify-content-end">
                <a asp-action="Index" class="btn btn-outline-custom">
                    Отмена
                </a>
                <button type="submit" class="btn btn-primary-gradient">
                    💾 Сохранить
                </button>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
